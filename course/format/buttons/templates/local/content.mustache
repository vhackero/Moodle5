<div id="course-format-{{uniqid}}">
    <h2 class="accesshide">{{{title}}}</h2>
    {{#coursedisplayname}}
        <div class="format-buttons-course-path">{{coursedisplayname}}</div>
    {{/coursedisplayname}}
    {{{completionhelp}}}
    <ul class="{{format}} section-list" data-for="course_sectionlist">
        {{#initialsection}}
            {{$ format_buttons/local/content/section }}
                {{> format_buttons/local/content/section }}
            {{/ format_buttons/local/content/section }}
        {{/initialsection}}
        {{!btms}}
        {{^isarrownavigation}}
            {{#all_sections}}
                {{#body}}
                    <b class="text-black">{{{text_section}}}</b>
                    {{#selected}}
                        <a href="{{{url}}}" class="btn btn-primary font-weight-bold {{disabled}} border-0"
                           style="display: inline-flex; align-items: center; justify-content: center; min-width: 50px;
                                   min-height: 50px; border-radius: {{{form_btn}}}; background-color: {{bgcolor_selected}}; margin: 5px;
                                   font-size: 1.5em; text-decoration: none; color: {{fontcolor_selected}};">
                            {{{displaysection}}}
                        </a>
                    {{/selected}}
                    {{^selected}}
                        <a href="{{{url}}}" class="btn btn-primary font-weight-bold {{disabled}} border-0"
                           style="display: inline-flex; align-items: center; justify-content: center; min-width: 50px;
                                   min-height: 50px; border-radius: {{{form_btn}}}; background-color: {{bgcolor}}; margin: 5px;
                                   font-size: 1.5em; text-decoration: none; color: {{colorfont}};">
                            {{{displaysection}}}
                        </a>
                    {{/selected}}
                {{/body}}
            {{/all_sections}}
        {{/isarrownavigation}}
        {{#image_init_sectios}}
            <img src="{{{image_init_sectios}}}" class="w-100 m-5 border-radius"/>
        {{/image_init_sectios}}
        {{#section}}
        {{/section}}
        {{! end btms}}
        {{#sections}}
            {{$ format_buttons/local/content/section }}
                {{> format_buttons/local/content/section }}
            {{/ format_buttons/local/content/section }}
        {{/sections}}
    </ul>
    {{#hasnavigation}}
    {{/hasnavigation}}
    {{#numsections}}
        {{^singlesection}}
            {{$ core_courseformat/local/content/addsection}}
                {{> core_courseformat/local/content/addsection}}
            {{/ core_courseformat/local/content/addsection}}
        {{/singlesection}}
    {{/numsections}}
    {{#bulkedittools}}
        {{$ core_courseformat/local/content/bulkedittools}}
            {{> core_courseformat/local/content/bulkedittools}}
        {{/ core_courseformat/local/content/bulkedittools}}
    {{/bulkedittools}}
</div>
{{#sectionselector}}
    {{$ format_buttons/local/content/sectionselector }}
        {{> format_buttons/local/content/sectionselector }}
    {{/ format_buttons/local/content/sectionselector }}
{{/sectionselector}}

{{#js}}
    require(['core_courseformat/local/content'], function(component) {
    component.init('#page', {}, {{sectionreturn}});
    {{#hidecourseindexactivities}}
    document.body.classList.add('format-buttons-hide-courseindex-activities');
    {{/hidecourseindexactivities}}
    });
{{/js}}

<style>
    .format-buttons-course-path {margin: .5rem 0 1rem; color: #6c757d; font-size: 1.05rem;}
    .format-buttons-section-title {color:#4d2433; font-weight:700;}
    .format-buttons-week-stripe {height: 1.5rem; width:100%; background-repeat: repeat-x; background-size: auto 100%; margin:0 0 .6rem 0;}
    .format-buttons-week-title {background:#d8d8d8; border-radius:.35rem; padding:1rem; text-align:center; margin: 0 0 1rem 0; width: 100%;}
    .format-buttons-week-name {margin:0; font-size:2rem; font-weight:700;}
    .format-buttons-week-range {margin:.35rem 0 0; font-size:1.2rem; color:#4f4f4f;}
    .format-buttons-activity-columns {display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1rem;}
    .format-buttons-uncategorized {margin-bottom: 1rem;}
    .format-buttons-bottom-nav {gap: .8rem;}
    .format-buttons-bottom-nav .format-buttons-nav-arrow {display:inline-flex; align-items:center; gap:.4rem; font-size: 1rem; text-decoration: none; padding: .5rem .9rem; border-radius: 999px; font-weight:600; box-shadow: 0 2px 8px rgba(0,0,0,.12);}
    .format-buttons-current-section-number {display:inline-flex; min-width:2.5rem; min-height:2.5rem; align-items:center; justify-content:center; border-radius:999px; font-weight:700; box-shadow: 0 2px 8px rgba(0,0,0,.12);}
    .format-buttons-column-title {background:#d8d8d8; border-radius:.35rem; padding:.8rem 1rem; text-align:center; font-weight:700; height: 5rem; align-content: center;}
    .format-buttons-column .activity-item {background:#fff; border:1px solid #e1e1e1; border-radius:.6rem; margin:.6rem 0; padding:.8rem; overflow-wrap:anywhere; word-break:break-word; display:block;}
    .format-buttons-column .activity-item > * {max-width: 100%;}
    .format-buttons-column .activity-item .activity-instance,
    .format-buttons-column .activity-item .activity-item-content,
    .format-buttons-column .activity-item .activityname,
    .format-buttons-column .activity-item .instancename {display:block !important; width:100% !important; min-width:0 !important;}
    .format-buttons-column .activity-item .activity-instance {order: 1;}
    .format-buttons-column .activity-item .activity-actions,
    .format-buttons-column .activity-item .activity-altcontent,
    .format-buttons-column .activity-item .actions,
    .format-buttons-column .activity-item .activity-information,
    .format-buttons-column .activity-item [data-region="completion-info"] {
        order: 2;
        display:flex;
        flex-wrap:wrap;
        gap:.4rem;
        margin-top:.5rem;
        margin-left:0 !important;
        justify-content:flex-start;
        width:100%;
        flex-basis:100%;
    }
    .format-buttons-column .activity-item button,
    .format-buttons-column .activity-item .btn {white-space: normal; max-width:100%;}
    .format-buttons-column .activity-item .activityname,
    .format-buttons-column .activity-item .instancename {overflow-wrap:anywhere; word-break:break-word;}
    .format-buttons-column .activity-grid {display: block;}
    .format-buttons-column ul {padding: 0;}
    body:not(.editing) .format-buttons-activity-columns .activity-actions,
    body:not(.editing) .format-buttons-activity-columns .dropdown-toggle,
    body:not(.editing) .format-buttons-uncategorized .activity-actions,
    body:not(.editing) .format-buttons-uncategorized .dropdown-toggle {
        display: none !important;
    }
    @media (max-width: 992px) {.format-buttons-activity-columns {grid-template-columns:1fr;}}
    #page-course-view-buttons.format-buttons-hide-courseindex-activities .courseindex [data-for="cm"],
    #page-course-view-buttons.format-buttons-hide-courseindex-activities .courseindex .courseindex-cm {
        display:none !important;
    }
</style>
