<div id="course-format-{{uniqid}}">
    <h2 class="accesshide">{{{title}}}</h2>
    {{#coursedisplayname}}
        <div class="format-buttons-course-path">{{coursedisplayname}}</div>
    {{/coursedisplayname}}
    {{#isarrownavigation}}
        <div class="format-buttons-arrow-nav">
            {{#arrownavigation.hasprevious}}
                <a class="arrow-link arrow-prev" href="{{{arrownavigation.previousurl}}}">&#8592;</a>
            {{/arrownavigation.hasprevious}}
            <div class="arrow-current">
                <span class="arrow-current-label">{{arrownavigation.currentlabel}}</span>
                <span class="arrow-current-name">{{arrownavigation.currentname}}</span>
            </div>
            {{#arrownavigation.hasnext}}
                <a class="arrow-link arrow-next" href="{{{arrownavigation.nexturl}}}">&#8594;</a>
            {{/arrownavigation.hasnext}}
        </div>
    {{/isarrownavigation}}
    {{{completionhelp}}}
    <ul class="{{format}} section-list" data-for="course_sectionlist">
        {{#initialsection}}
            {{$ format_buttons/local/content/section }}
                {{> format_buttons/local/content/section }}
            {{/ format_buttons/local/content/section }}
        {{/initialsection}}
        {{!btms}}
        {{^isarrownavigation}}
            {{#all_sections}}
                {{#body}}
                    <b class="text-black">{{{text_section}}}</b>
                    {{#selected}}
                        <a href="{{{url}}}" class="btn btn-primary font-weight-bold {{disabled}} border-0"
                           style="display: inline-flex; align-items: center; justify-content: center; min-width: 50px;
                                   min-height: 50px; border-radius: {{{form_btn}}}; background-color: {{bgcolor_selected}}; margin: 5px;
                                   font-size: 1.5em; text-decoration: none; color: {{fontcolor_selected}};">
                            {{displaysection}}
                        </a>
                    {{/selected}}
                    {{^selected}}
                        <a href="{{{url}}}" class="btn btn-primary font-weight-bold {{disabled}} border-0"
                           style="display: inline-flex; align-items: center; justify-content: center; min-width: 50px;
                                   min-height: 50px; border-radius: {{{form_btn}}}; background-color: {{bgcolor}}; margin: 5px;
                                   font-size: 1.5em; text-decoration: none; color: {{colorfont}};">
                            {{displaysection}}
                        </a>
                    {{/selected}}
                {{/body}}
            {{/all_sections}}
        {{/isarrownavigation}}
        {{#image_init_sectios}}
            <img src="{{{image_init_sectios}}}" class="w-100 m-5 border-radius"/>
        {{/image_init_sectios}}
        {{#section}}
        {{/section}}
        {{! end btms}}
        {{#sections}}
            {{$ format_buttons/local/content/section }}
                {{> format_buttons/local/content/section }}
            {{/ format_buttons/local/content/section }}
        {{/sections}}
    </ul>
    {{#hasnavigation}}
    {{/hasnavigation}}
    {{#numsections}}
        {{^singlesection}}
            {{$ core_courseformat/local/content/addsection}}
                {{> core_courseformat/local/content/addsection}}
            {{/ core_courseformat/local/content/addsection}}
        {{/singlesection}}
    {{/numsections}}
    {{#bulkedittools}}
        {{$ core_courseformat/local/content/bulkedittools}}
            {{> core_courseformat/local/content/bulkedittools}}
        {{/ core_courseformat/local/content/bulkedittools}}
    {{/bulkedittools}}
</div>
{{#sectionselector}}
    {{$ format_buttons/local/content/sectionselector }}
        {{> format_buttons/local/content/sectionselector }}
    {{/ format_buttons/local/content/sectionselector }}
{{/sectionselector}}

{{#js}}
    require(['core_courseformat/local/content'], function(component) {
    component.init('#page', {}, {{sectionreturn}});
    {{#hidecourseindexactivities}}
    document.body.classList.add('format-buttons-hide-courseindex-activities');
    {{/hidecourseindexactivities}}
    });
{{/js}}

<style>
    .format-buttons-course-path {margin: .5rem 0 1rem; color: #6c757d; font-size: 1.05rem;}
    .format-buttons-arrow-nav {display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem;}
    .format-buttons-arrow-nav .arrow-link {font-size: 1.6rem; text-decoration: none; padding: .35rem .75rem; background: #e7e7e7; border-radius: 999px;}
    .format-buttons-arrow-nav .arrow-current {display:flex; align-items:center; gap:.7rem; flex-wrap:wrap;}
    .format-buttons-arrow-nav .arrow-current-label {display:inline-flex; min-width:2.3rem; min-height:2.3rem; align-items:center; justify-content:center; background:#4d2433; color:#fff; border-radius:999px; font-weight:700;}
    .format-buttons-arrow-nav .arrow-current-name {font-weight:700; font-size:1.2rem; color:#4d2433;}
    .format-buttons-section-title {color:#4d2433; font-weight:700;}
    .format-buttons-activity-columns {display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1rem;}
    .format-buttons-uncategorized {margin-bottom: 1rem;}
    .format-buttons-column-title {background:#d8d8d8; border-radius:.35rem; padding:.8rem 1rem; text-align:center; font-weight:700;}
    .format-buttons-column .activity-item {background:#fff; border:1px solid #e1e1e1; border-radius:.6rem; margin:.6rem 0; padding:.6rem;}
    @media (max-width: 992px) {.format-buttons-activity-columns {grid-template-columns:1fr;}}
    #page-course-view-buttons.format-buttons-hide-courseindex-activities .courseindex [data-for="cm"],
    #page-course-view-buttons.format-buttons-hide-courseindex-activities .courseindex .courseindex-cm {
        display:none !important;
    }
</style>
